generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Worker {
  id        Int       @id @default(autoincrement())
  login     String    @unique
  password  String
  fullName  String
  role      Role      @default(WORKER)
  active    Boolean   @default(true)
  reports      Report[]
  paymentLines PaymentLine[]
  auditLogs    AuditLog[]
  createdAt    DateTime      @default(now())
  updatedAt DateTime  @updatedAt
}

model Category {
  id        Int         @id @default(autoincrement())
  name      String      @unique
  items     PriceItem[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model PriceItem {
  id          Int          @id @default(autoincrement())
  categoryId  Int
  category    Category     @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  name          String
  unit          String
  price         Float?      // основная цена для работника
  customerPrice Float?      // цена для заказчика, нужна работодателю

  // Для листа «Декоративка»: один пункт прайса, но работник выбирает вид работы.
  priceCutPolish Float?
  priceCut       Float?
  pricePolish    Float?

  reportItems ReportItem[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Report {
  id          Int          @id @default(autoincrement())
  workerId    Int
  worker      Worker       @relation(fields: [workerId], references: [id], onDelete: Cascade)

  orderNumber String
  workDate    DateTime
  total       Float        @default(0)
  items       ReportItem[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model ReportItem {
  id          Int        @id @default(autoincrement())

  reportId    Int
  report      Report     @relation(fields: [reportId], references: [id], onDelete: Cascade)

  priceItemId Int
  priceItem   PriceItem  @relation(fields: [priceItemId], references: [id])

  quantity      Float
  price         Float
  total         Float
  operationType String?
  operationName String?
  status        String     @default("PENDING")
  rejectComment String?

  paymentLineId Int?
  paymentLine   PaymentLine? @relation(fields: [paymentLineId], references: [id])

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model Payment {
  id          Int           @id @default(autoincrement())
  periodFrom  DateTime
  periodTo    DateTime
  status      String        @default("CREATED") // CREATED / PAID
  total       Float         @default(0)
  paidAt      DateTime?
  lines       PaymentLine[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model PaymentLine {
  id          Int          @id @default(autoincrement())
  paymentId   Int
  payment     Payment      @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  workerId    Int
  worker      Worker       @relation(fields: [workerId], references: [id])
  workerName  String

  worksTotal  Float        @default(0)
  adjustment  Float        @default(0)
  finalTotal  Float        @default(0)
  note        String?

  items       ReportItem[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  actorId     Int?
  actor       Worker?  @relation(fields: [actorId], references: [id], onDelete: SetNull)
  actorName   String?
  action      String
  entityType  String
  entityId    String
  description String
  createdAt   DateTime @default(now())
}

model PriceImport {
  id            Int      @id @default(autoincrement())
  fileName      String
  version       String
  sectionsCount Int      @default(0)
  itemsCount    Int      @default(0)
  uploadedBy    String?
  uploadedAt    DateTime @default(now())
}

enum Role {
  ADMIN
  WORKER
}
